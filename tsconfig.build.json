{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "removeComments": false
  },
  "include": ["src"],
  "exclude": ["node_modules", ".coverage", "dist", "test", "**/*.test.ts", "**/*.spec.ts"]
}
