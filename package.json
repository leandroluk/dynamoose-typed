{
  "name": "@leandroluk/dynamoose-typed",
  "version": "1.0.1",
  "description": "A strongly-typed, decorator-driven ODM wrapper around Dynamoose",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "tsup",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts --fix",
    "tsc": "tsc --noEmit"
  },
  "keywords": [
    "dynamoose",
    "dynamodb",
    "typescript",
    "types",
    "decorators",
    "orm",
    "odm",
    "aws",
    "database"
  ],
  "author": {
    "name": "Leandro Santiago Gomes",
    "email": "leandroluk@gmail.com",
    "url": "https://linkedin.com/in/leandroluk"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leandroluk/dynamoose-typed.git"
  },
  "bugs": {
    "url": "https://github.com/leandroluk/dynamoose-typed/issues"
  },
  "homepage": "https://github.com/leandroluk/dynamoose-typed#readme",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@eslint/js": "10.0.1",
    "@swc/core": "^1.15.26",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/eslint-plugin": "1.6.16",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.5.0",
    "jiti": "2.6.1",
    "lefthook": "2.1.6",
    "tsup": "8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.58.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "4.1.4"
  },
  "dependencies": {
    "dynamoose": "4.1.5",
    "uuid": "13.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "lefthook"
    ]
  }
}