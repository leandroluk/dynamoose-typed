{
  "name": "@leandroluk/dynamoose-typed",
  "version": "1.10.4",
  "description": "A strongly-typed, decorator-driven ODM wrapper around Dynamoose",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "index": [
        "./dist/index.d.ts"
      ],
      "testing": [
        "./dist/testing/index.d.ts"
      ]
    }
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "tsup && tsc -p tsconfig.build.json && node scripts/fix-dts-aliases.mjs",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint . --type-aware --fix",
    "format": "oxfmt --write src test .examples",
    "tsc": "tsc --noEmit"
  },
  "keywords": [
    "dynamoose",
    "dynamodb",
    "typescript",
    "types",
    "decorators",
    "orm",
    "odm",
    "aws",
    "database"
  ],
  "author": {
    "name": "Leandro Santiago Gomes",
    "email": "leandroluk@gmail.com",
    "url": "https://linkedin.com/in/leandroluk"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leandroluk/dynamoose-typed.git"
  },
  "bugs": {
    "url": "https://github.com/leandroluk/dynamoose-typed/issues"
  },
  "homepage": "https://leandroluk.github.io/dynamoose-typed",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "3.1089.0",
    "@aws-sdk/client-dynamodb-streams": "3.1089.0",
    "@aws-sdk/util-dynamodb": "3.996.7",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@commitlint/types": "21.2.0",
    "@swc/core": "1.15.43",
    "@vitest/coverage-v8": "4.1.10",
    "dynamoose": "4.2.0",
    "jiti": "2.7.0",
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "tsup": "8.5.1",
    "typescript": "7.0.2",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": ">=3",
    "@aws-sdk/client-dynamodb-streams": ">=3",
    "@aws-sdk/util-dynamodb": ">=3",
    "dynamoose": ">=4.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}