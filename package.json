{
  "name": "@leandroluk/dynamoose-typed",
  "version": "1.3.0",
  "description": "A strongly-typed, decorator-driven ODM wrapper around Dynamoose",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "index": [
        "./dist/index.d.ts"
      ],
      "testing": [
        "./dist/testing.d.ts"
      ]
    }
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "tsup",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "tsc": "tsc --noEmit"
  },
  "keywords": [
    "dynamoose",
    "dynamodb",
    "typescript",
    "types",
    "decorators",
    "orm",
    "odm",
    "aws",
    "database"
  ],
  "author": {
    "name": "Leandro Santiago Gomes",
    "email": "leandroluk@gmail.com",
    "url": "https://linkedin.com/in/leandroluk"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leandroluk/dynamoose-typed.git"
  },
  "bugs": {
    "url": "https://github.com/leandroluk/dynamoose-typed/issues"
  },
  "homepage": "https://leandroluk.github.io/dynamoose-typed",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "3.1052.0",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@commitlint/types": "21.0.1",
    "@eslint/js": "10.0.1",
    "@swc/core": "1.15.26",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/eslint-plugin": "1.6.16",
    "dynamoose": "4.2.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.5.0",
    "jiti": "2.6.1",
    "lefthook": "2.1.6",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": ">=3",
    "dynamoose": ">=4.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
